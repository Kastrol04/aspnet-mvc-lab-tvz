@model VozniRedVlakova.Models.EntityIndexViewModel
@using System.Reflection
@{
    ViewData["Title"] = $"{Model.EntityTitle} - Lista";

    object? FormatValue(object? value)
    {
        if (value is null) return "-";
        if (value is DateTime dt) return dt.ToString("dd.MM.yyyy HH:mm");
        if (value is bool b) return b ? "Da" : "Ne";

        if (value is IEnumerable<object> objEnumerable && value is not string)
        {
            return $"{objEnumerable.Count()} stavki";
        }

        if (value is System.Collections.IEnumerable enumerable && value is not string)
        {
            var count = 0;
            foreach (var _ in enumerable)
            {
                count++;
            }

            return $"{count} stavki";
        }

        var type = value.GetType();
        if (type.IsClass && type != typeof(string))
        {
            var nazivProp = type.GetProperty("Naziv")?.GetValue(value)?.ToString();
            var brojProp = type.GetProperty("Broj")?.GetValue(value)?.ToString();
            if (!string.IsNullOrWhiteSpace(nazivProp)) return nazivProp;
            if (!string.IsNullOrWhiteSpace(brojProp)) return brojProp;
            return type.Name;
        }

        return value;
    }

    var itemType = Model.Items.FirstOrDefault()?.GetType();
    var allProps = itemType?.GetProperties(BindingFlags.Public | BindingFlags.Instance)
        .Where(p => p.CanRead)
        .Where(p => p.Name != "Id")
        .ToList() ?? new List<PropertyInfo>();

    var primaryProps = allProps.Take(5).ToList();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item">@Model.EntityTitle</li>
        <li class="breadcrumb-item active" aria-current="page">Lista</li>
    </ol>
</nav>

<section class="page-header mb-3">
    <h1 class="h3 page-header__title">@Model.EntityTitle - lista</h1>
    <p class="text-muted mb-0">Pregled svih zapisa i pristup detaljima.</p>
</section>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-secondary" role="status">Nema dostupnih podataka za ovaj entitet.</div>
}
else
{
    <div class="card shadow-sm border-0 entity-table">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <caption>@Model.EntityTitle - tablični prikaz</caption>
                    <thead>
                        <tr>
                            <th scope="col">Id</th>
                            @foreach (var prop in primaryProps)
                            {
                                <th scope="col">@prop.Name</th>
                            }
                            <th scope="col" class="text-end">Akcije</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var itemIdObj = item.GetType().GetProperty("Id")?.GetValue(item);
                            var itemId = itemIdObj is int idValue ? idValue : 0;
                            <tr>
                                <th scope="row">
                                    <a asp-action="Details" asp-route-entity="@Model.EntityKey" asp-route-id="@itemId">@itemId</a>
                                </th>
                                @foreach (var prop in primaryProps)
                                {
                                    var raw = prop.GetValue(item);
                                    <td>@FormatValue(raw)</td>
                                }
                                <td class="text-end entity-table__actions">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-entity="@Model.EntityKey" asp-route-id="@itemId">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
