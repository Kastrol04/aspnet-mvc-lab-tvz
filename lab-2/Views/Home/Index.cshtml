@model VozniRedVlakova.Models.HomeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-header mb-4">
    <h1 class="display-6 page-header__title">Vozni red vlakova</h1>
    <p class="text-muted page-header__meta mb-0">Centralni pregled svih entiteta i podataka iz mock repozitorija.</p>
</section>

<section class="content-section mb-4" aria-label="Sažetak podataka">
    <div class="row g-3">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-kpi shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted">Putnički vlakovi</h2>
                    <p class="display-6 dashboard-kpi__value mb-0">@Model.UkupnoVlakova</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-kpi shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted">Stanice</h2>
                    <p class="display-6 dashboard-kpi__value mb-0">@Model.UkupnoStanica</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-kpi shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted">Voznje</h2>
                    <p class="display-6 dashboard-kpi__value mb-0">@Model.UkupnoVoznji</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-kpi shadow-sm border-0 h-100">
                <div class="card-body">
                    <h2 class="h6 text-muted">Karte</h2>
                    <p class="display-6 dashboard-kpi__value mb-0">@Model.UkupnoKarata</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="content-section" aria-label="Brzi pristup entitetima">
    <h2 class="h5 mb-3">Brzi pristup</h2>
    <div class="row g-3">
        @foreach (var navItem in Model.Navigacija)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <h3 class="h6 mb-2">@navItem.Title</h3>
                        <a class="btn btn-outline-primary btn-sm align-self-start" asp-controller="Pregled" asp-action="Index" asp-route-entity="@navItem.Key">
                            Otvori listu
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
